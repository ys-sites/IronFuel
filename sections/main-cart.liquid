<div class="cart-page">
  <h1 class="cart-page-title">YOUR CART</h1>

  {% if cart.item_count == 0 %}
    <div class="cart-page-empty">
      <svg xmlns="http://www.w3.org/2000/svg" width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" style="color:rgba(255,255,255,0.1);margin:0 auto 1.5rem;display:block;"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z"/><path d="M3 6h18"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
      <h2>Your cart is empty</h2>
      <p>Add some products to get started.</p>
      <br>
      <a href="{{ routes.all_products_collection_url }}" class="btn-primary" style="display:inline-flex;text-decoration:none;">SHOP NOW</a>
    </div>
  {% else %}
    {%- form 'cart', cart -%}
      <div class="cart-page-items">
        {% for item in cart.items %}
          <div class="cart-page-item">
            <div>
              {% if item.image %}
                <img
                  src="{{ item.image | image_url: width: 200 }}"
                  alt="{{ item.image.alt | escape }}"
                  class="cart-page-item-img">
              {% endif %}
            </div>
            <div>
              <p class="cart-page-item-title">{{ item.product.title }}</p>
              {% unless item.product.has_only_default_variant %}
                <p class="cart-page-item-variant">{{ item.variant.title }}</p>
              {% endunless %}
              <div class="cart-page-qty">
                <button type="button" class="qty-btn" onclick="updateCartItem('{{ item.key }}', {{ item.quantity | minus: 1 }})">−</button>
                <span class="qty-value">{{ item.quantity }}</span>
                <button type="button" class="qty-btn" onclick="updateCartItem('{{ item.key }}', {{ item.quantity | plus: 1 }})">+</button>
              </div>
            </div>
            <div style="text-align:right;">
              <p class="cart-page-item-price">{{ item.line_price | money }}</p>
              <button type="button" class="cart-page-remove" onclick="updateCartItem('{{ item.key }}', 0)">Remove</button>
            </div>
          </div>
        {% endfor %}
      </div>

      <div class="cart-page-summary">
        <div class="cart-page-subtotal">
          <span class="cart-page-subtotal-label">Subtotal</span>
          <span class="cart-page-subtotal-value">{{ cart.total_price | money }}</span>
        </div>
        <p class="cart-page-note">Taxes and shipping calculated at checkout.</p>
        <button type="submit" name="checkout" class="checkout-btn-full">CHECKOUT</button>
      </div>
    {%- endform -%}

    <a href="{{ routes.all_products_collection_url }}" class="continue-shopping">← CONTINUE SHOPPING</a>
  {% endif %}
</div>

{% schema %}
{
  "name": "Cart Page",
  "settings": [],
  "presets": [
    {
      "name": "Cart Page"
    }
  ]
}
{% endschema %}
