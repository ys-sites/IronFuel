<div class="blog-page">
  <h1 class="blog-page-title">{{ blog.title }}</h1>

  {% if blog.articles_count == 0 %}
    <p style="color:rgba(255,255,255,0.4);text-align:center;padding:4rem 0;">No articles yet. Check back soon.</p>
  {% else %}
    <div class="blog-grid">
      {% paginate blog.articles by 9 %}
        {% for article in blog.articles %}
          <a href="{{ article.url }}" class="blog-card">
            {% if article.image %}
              <img
                src="{{ article.image | image_url: width: 800 }}"
                alt="{{ article.image.alt | escape }}"
                class="blog-card-img"
                loading="lazy">
            {% endif %}
            <div class="blog-card-content">
              <p class="blog-card-date">{{ article.published_at | date: "%B %d, %Y" }}</p>
              <h2 class="blog-card-title">{{ article.title }}</h2>
              <p class="blog-card-excerpt">{{ article.excerpt_or_content | strip_html | truncate: 120 }}</p>
            </div>
          </a>
        {% endfor %}

        {% if paginate.pages > 1 %}
          <div class="pagination" style="grid-column:1/-1;">
            {{ paginate | default_pagination }}
          </div>
        {% endif %}
      {% endpaginate %}
    </div>
  {% endif %}
</div>

{% schema %}
{
  "name": "Blog Posts",
  "settings": [],
  "presets": [
    {
      "name": "Blog Posts"
    }
  ]
}
{% endschema %}
