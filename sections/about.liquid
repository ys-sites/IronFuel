<section class="about-section" id="About-{{ section.id }}">
  <div class="about-container">
    <div class="about-grid">
      <div class="about-image-wrapper reveal-element">
        <img src="{% if section.settings.image %}{{ section.settings.image | image_url: width: 800 }}{% else %}{{ 'Ashwagandha1.jpeg' | asset_url }}{% endif %}" 
             alt="Science Behind Fuel" 
             class="about-img">
      </div>
      
      <div class="about-content reveal-element">
        <div class="section-header align-left">
          <h2 class="section-title">{{ section.settings.title }}</h2>
          <p class="section-subtitle">{{ section.settings.subtitle }}</p>
        </div>
        
        <div class="about-accordion">
          {% for block in section.blocks %}
            <div class="accordion-item">
              <button class="accordion-header" onclick="this.parentElement.classList.toggle('active')">
                <span class="accordion-icon">{{ block.settings.icon }}</span>
                <span class="accordion-title">{{ block.settings.title }}</span>
                <svg class="chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 9l6 6 6-6"/></svg>
              </button>
              <div class="accordion-content">
                <p>{{ block.settings.content }}</p>
              </div>
            </div>
          {% endfor %}
        </div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "About Section",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Section Image"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "SCIENCE BEHIND THE FUEL"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Every Iron Fuel Lab product is formulated based on peer-reviewed research and pharmaceutical-grade standards."
    }
  ],
  "blocks": [
    {
      "type": "point",
      "name": "Point",
      "settings": [
        {
          "type": "text",
          "id": "icon",
          "label": "Emoji/Icon",
          "default": "🔬"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Pharmaceutical Grade"
        },
        {
          "type": "textarea",
          "id": "content",
          "label": "Content",
          "default": "Our supplements are produced in FDA-registered facilities following strict cGMP protocols to ensure purity and potency."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "About Section",
      "blocks": [
        { "type": "point" },
        { "type": "point" },
        { "type": "point" }
      ]
    }
  ]
}
{% endschema %}
