<section class="products-section" id="Products-{{ section.id }}">
  <div class="products-container">
    <div class="section-header">
      <h2 class="section-title">{{ section.settings.title }}</h2>
      <p class="section-subtitle">{{ section.settings.subtitle }}</p>
    </div>

    <div class="products-grid">
      {% assign featured_collection = collections[section.settings.collection] %}
      {% if featured_collection != blank %}
        {% for product in featured_collection.products limit: section.settings.products_to_show %}
          <div class="product-card reveal-element">
            <a href="{{ product.url }}" class="product-image-container">
              {% if product.featured_image %}
                <img
                  src="{{ product.featured_image | image_url: width: 600 }}"
                  alt="{{ product.featured_image.alt | escape }}"
                  class="product-img"
                  loading="lazy"
                  width="600"
                  height="600">
              {% else %}
                <div class="product-img-placeholder"></div>
              {% endif %}
            </a>
            <div class="product-info">
              <h3 class="product-name">{{ product.title }}</h3>
              <p class="product-desc">{{ product.description | strip_html | truncate: 90 }}</p>
              <div class="product-footer">
                <div class="product-price">
                  {% if product.compare_at_price > product.price %}
                    <span class="price-sale">{{ product.price | money }}</span>
                    <span class="price-compare">{{ product.compare_at_price | money }}</span>
                  {% else %}
                    {{ product.price | money }}
                  {% endif %}
                </div>
                <div class="product-actions">
                  <button
                    class="add-btn"
                    style="background-color: {{ section.settings.button_color }}; color: white;"
                    data-variant-id="{{ product.selected_or_first_available_variant.id }}"
                    {% unless product.available %}disabled{% endunless %}
                    onclick="addToCart({{ product.selected_or_first_available_variant.id }}, this)">
                    {% if product.available %}ADD TO CART{% else %}SOLD OUT{% endif %}
                  </button>
                  <a href="{{ product.url }}" class="view-details-btn">DETAILS</a>
                </div>
              </div>
            </div>
          </div>
        {% else %}
          <p class="products-empty">No products found in this collection.</p>
        {% endfor %}
      {% else %}
        {% for product in collections.all.products limit: section.settings.products_to_show %}
          <div class="product-card reveal-element">
            <a href="{{ product.url }}" class="product-image-container">
              {% if product.featured_image %}
                <img
                  src="{{ product.featured_image | image_url: width: 600 }}"
                  alt="{{ product.featured_image.alt | escape }}"
                  class="product-img"
                  loading="lazy"
                  width="600"
                  height="600">
              {% else %}
                <div class="product-img-placeholder"></div>
              {% endif %}
            </a>
            <div class="product-info">
              <h3 class="product-name">{{ product.title }}</h3>
              <p class="product-desc">{{ product.description | strip_html | truncate: 90 }}</p>
              <div class="product-footer">
                <div class="product-price">{{ product.price | money }}</div>
                <div class="product-actions">
                  <button
                    class="add-btn"
                    style="background-color: {{ section.settings.button_color }}; color: white;"
                    data-variant-id="{{ product.selected_or_first_available_variant.id }}"
                    {% unless product.available %}disabled{% endunless %}
                    onclick="addToCart({{ product.selected_or_first_available_variant.id }}, this)">
                    {% if product.available %}ADD TO CART{% else %}SOLD OUT{% endif %}
                  </button>
                  <a href="{{ product.url }}" class="view-details-btn">DETAILS</a>
                </div>
              </div>
            </div>
          </div>
        {% endfor %}
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Products Grid",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Section Title",
      "default": "ENGINEERED PROTOCOLS"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Section Subtitle",
      "default": "Scientifically backed formulas for peak human performance."
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection to show"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "label": "Products to show",
      "min": 2,
      "max": 12,
      "step": 1,
      "default": 6
    },
    {
      "type": "color",
      "id": "button_color",
      "label": "Button Color",
      "default": "#4ca735"
    }
  ],
  "presets": [
    {
      "name": "Products Grid"
    }
  ]
}
{% endschema %}
