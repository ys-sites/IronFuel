<section class="products-section" id="Products-{{ section.id }}">
  <div class="products-container">
    <div class="section-header">
      <h2 class="section-title">ENGINEERED PROTOCOLS</h2>
      <p class="section-subtitle">Scientifically backed formulas for peak human performance.</p>
    </div>

    <!-- Shopify List Context for Products -->
    <shopify-list-context type="product" query="products" first="12">
      <template>
        <div class="product-card reveal-element">
          <div class="product-image-container">
            <shopify-media 
              width="600" 
              height="600" 
              query="product.selectedOrFirstAvailableVariant.image"
              layout="constrained"
              class="product-img">
            </shopify-media>
          </div>
          
          <div class="product-info">
            <h3 class="product-name">
              <shopify-data query="product.title"></shopify-data>
            </h3>
            <p class="product-desc">
              <!-- Using a simple description query -->
              <shopify-data query="product.description"></shopify-data>
            </p>
            
            <div class="product-footer">
              <div class="product-price">
                <shopify-money query="product.selectedOrFirstAvailableVariant.price"></shopify-money>
              </div>
              
              <!-- Quick Add Action -->
              <button class="add-btn" 
                      onclick="document.getElementById('MainCart').addLine(event).showModal();">
                ADD TO CART
              </button>
              
              <!-- View Details Action -->
              <button class="view-details-btn"
                      onclick="document.getElementById('ProductModal').showModal(); document.getElementById('ProductModalContext').update(event);">
                DETAILS
              </button>
            </div>
          </div>
        </div>
      </template>
      
      <!-- Loading State -->
      <div shopify-loading-placeholder class="products-loading">
        <div class="loader"></div>
        <p>Initializing Protocols...</p>
      </div>
    </shopify-list-context>
  </div>
</section>

<!-- Global Product Details Modal -->
<dialog id="ProductModal" class="product-modal">
  <shopify-context id="ProductModalContext" type="product" wait-for-update>
    <template>
      <div class="modal-content">
        <button class="modal-close" onclick="document.getElementById('ProductModal').close();">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 6L6 18M6 6l12 12"/></svg>
        </button>
        
        <div class="modal-grid">
          <div class="modal-media">
            <shopify-media width="500" height="500" query="product.selectedOrFirstAvailableVariant.image"></shopify-media>
          </div>
          
          <div class="modal-details">
            <div class="modal-header">
              <span class="modal-vendor"><shopify-data query="product.vendor"></shopify-data></span>
              <h2 class="modal-title"><shopify-data query="product.title"></shopify-data></h2>
              <div class="modal-price">
                <shopify-money query="product.selectedOrFirstAvailableVariant.price"></shopify-money>
              </div>
            </div>
            
            <div class="modal-options">
              <shopify-variant-selector></shopify-variant-selector>
            </div>
            
            <div class="modal-actions">
              <button class="modal-add-btn" 
                      onclick="document.getElementById('MainCart').addLine(event).showModal();"
                      shopify-attr--disabled="!product.selectedOrFirstAvailableVariant.availableForSale">
                ADD TO PROTOCOL
              </button>
              
              <button class="modal-buy-btn"
                      onclick="document.querySelector('shopify-store').buyNow(event)"
                      shopify-attr--disabled="!product.selectedOrFirstAvailableVariant.availableForSale">
                BUY NOW
              </button>
            </div>
            
            <div class="modal-description">
              <shopify-data query="product.descriptionHtml"></shopify-data>
            </div>
          </div>
        </div>
      </div>
    </template>
  </shopify-context>
</dialog>

{% schema %}
{
  "name": "Shopify Products Grid",
  "settings": [],
  "presets": [
    {
      "name": "Shopify Products Grid"
    }
  ]
}
{% endschema %}
