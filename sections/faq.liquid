<section class="faq-section" id="FAQ-{{ section.id }}">
  <div class="faq-container">
    <div class="faq-grid">
      <div class="faq-content reveal-element">
        <div class="section-header align-left">
          <h2 class="section-title">{{ section.settings.title }}</h2>
        </div>
        
        <div class="faq-list">
          {% for block in section.blocks %}
            <div class="faq-item">
              <button class="faq-question" onclick="this.parentElement.classList.toggle('active')">
                <span>{{ block.settings.question }}</span>
                <svg class="plus-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 5v14M5 12h14"/></svg>
              </button>
              <div class="faq-answer">
                <p>{{ block.settings.answer }}</p>
              </div>
            </div>
          {% endfor %}
        </div>
      </div>
      
      <div class="faq-image-wrapper reveal-element">
        <img src="{% if section.settings.image %}{{ section.settings.image | image_url: width: 800 }}{% else %}{{ 'guy.jpg' | asset_url }}{% endif %}" 
             alt="Athlete" 
             class="faq-img">
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "FAQ Section",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Section Image"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "FREQUENTLY ASKED"
    }
  ],
  "blocks": [
    {
      "type": "faq",
      "name": "FAQ",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Question",
          "default": "When will I see results?"
        },
        {
          "type": "textarea",
          "id": "answer",
          "label": "Answer",
          "default": "Most users report increased focus and energy within 30 minutes, with long-term hormonal balance improving over 2-4 weeks of consistent use."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "FAQ Section",
      "blocks": [
        { "type": "faq" },
        { "type": "faq" },
        { "type": "faq" }
      ]
    }
  ]
}
{% endschema %}
