<article class="article-page">
  <header class="article-header reveal-element">
    <p class="article-date">{{ article.published_at | date: "%B %d, %Y" }}</p>
    <h1 class="article-title">{{ article.title }}</h1>
    <p class="article-author">By {{ article.author }}</p>
  </header>

  {% if article.image %}
    <img
      src="{{ article.image | image_url: width: 1200 }}"
      alt="{{ article.image.alt | escape }}"
      class="article-img"
      loading="lazy">
  {% endif %}

  <div class="article-content reveal-element">
    {{ article.content }}
  </div>

  {% if blog.comments_enabled? %}
    <div class="article-comments" style="margin-top:4rem;padding-top:3rem;border-top:1px solid rgba(255,255,255,0.08);">
      <h2 style="font-size:1.5rem;font-weight:700;margin-bottom:2rem;">Comments ({{ article.comments_count }})</h2>
      {% for comment in article.comments %}
        <div style="padding:1.5rem;background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.08);border-radius:1rem;margin-bottom:1rem;">
          <p style="font-weight:700;margin-bottom:0.5rem;">{{ comment.author }}</p>
          <p style="color:rgba(255,255,255,0.6);font-size:0.875rem;margin-bottom:0.75rem;">{{ comment.created_at | date: "%B %d, %Y" }}</p>
          <p>{{ comment.content }}</p>
        </div>
      {% endfor %}

      {%- form 'new_comment', article -%}
        <h3 style="font-size:1.25rem;font-weight:700;margin-bottom:1.5rem;margin-top:2rem;">Leave a Comment</h3>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;margin-bottom:1rem;">
          <input type="text" name="comment[author]" placeholder="Name" class="search-input" required>
          <input type="email" name="comment[email]" placeholder="Email" class="search-input" required>
        </div>
        <textarea name="comment[body]" placeholder="Your comment..." rows="4" class="search-input" style="width:100%;border-radius:1rem;resize:vertical;margin-bottom:1rem;" required></textarea>
        <button type="submit" class="btn-primary">POST COMMENT</button>
      {%- endform -%}
    </div>
  {% endif %}

  <div style="margin-top:3rem;">
    <a href="{{ blog.url }}" class="continue-shopping">← BACK TO {{ blog.title | upcase }}</a>
  </div>
</article>

{% schema %}
{
  "name": "Article",
  "settings": [],
  "presets": [
    {
      "name": "Article"
    }
  ]
}
{% endschema %}
