<div style="padding: 4rem 2rem; max-width: 800px; margin: 0 auto; color: white;">
  <h1 style="font-size: clamp(2rem, 6vw, 4rem); font-weight: 900; font-style: italic; text-transform: uppercase; letter-spacing: -0.05em; margin-bottom: 2rem;">{{ page.title }}</h1>
  <div style="color: rgba(255,255,255,0.75); line-height: 1.8;">{{ page.content }}</div>
</div>

{% schema %}
{
  "name": "Page Content",
  "settings": []
}
{% endschema %}
