{% layout 'gift_card' %}

<div class="gift-card-page">
  <div class="gift-card-header">
    <a href="{{ routes.root_url }}" style="text-decoration:none;color:white;">
      <img src="{{ 'logo.png' | asset_url }}" alt="{{ shop.name }}" style="height:2.5rem;margin-bottom:1rem;display:block;margin-left:auto;margin-right:auto;">
    </a>
    <h1 style="font-size:1.5rem;font-weight:900;font-style:italic;text-transform:uppercase;">Your Gift Card</h1>
    <p style="color:rgba(255,255,255,0.5);margin-top:0.5rem;">{{ shop.name }}</p>
  </div>

  <div class="gift-card-box">
    <p class="gift-card-amount">{{ gift_card.initial_value | money }}</p>

    {% if gift_card.enabled == false or gift_card.expired %}
      <p style="color:#f87171;font-weight:700;margin-bottom:1rem;">
        {% if gift_card.expired %}This gift card has expired.{% else %}This gift card has been disabled.{% endif %}
      </p>
    {% endif %}

    <p style="color:rgba(255,255,255,0.5);font-size:0.875rem;margin-bottom:1rem;">
      Remaining balance: <strong style="color:white;">{{ gift_card.balance | money }}</strong>
    </p>

    <div class="gift-card-code" id="GiftCardCode">{{ gift_card.code | format_code }}</div>

    <button
      class="btn-primary"
      style="width:100%;margin-bottom:0.75rem;"
      onclick="navigator.clipboard.writeText('{{ gift_card.code }}').then(()=>{ this.textContent='COPIED!'; setTimeout(()=>this.textContent='COPY CODE',2000) })">
      COPY CODE
    </button>

    <a
      href="{{ shop.url }}"
      class="btn-secondary"
      style="display:block;text-align:center;text-decoration:none;">
      SHOP NOW
    </a>

    {% if gift_card.pass_url %}
      <a href="{{ gift_card.pass_url }}" style="display:block;text-align:center;margin-top:1rem;">
        <img src="{{ 'gift-card/add-to-apple-wallet.svg' | shopify_asset_url }}" alt="Add to Apple Wallet" style="height:2.5rem;display:inline-block;">
      </a>
    {% endif %}
  </div>
</div>
