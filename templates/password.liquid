<!DOCTYPE html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ shop.name }} — Coming Soon</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Outfit:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  {{ 'theme.css' | asset_url | stylesheet_tag }}
  {{ content_for_header }}
</head>
<body>
  <div class="password-page">
    <img src="{{ 'logo.png' | asset_url }}" alt="{{ shop.name }}" style="height:3rem;margin-bottom:2rem;">
    <p class="password-page-logo">{{ shop.name }}</p>
    <h1 class="password-page-title">COMING SOON</h1>
    <p class="password-page-text">We're working on something extraordinary. Enter the password to get early access.</p>

    {%- form 'storefront_password' -%}
      {% if form.errors %}
        <p style="color:#f87171;margin-bottom:1rem;font-size:0.875rem;">{{ form.errors | default_errors }}</p>
      {% endif %}
      <div class="password-form">
        <input
          type="password"
          name="password"
          placeholder="Enter password"
          class="password-input"
          required
          autofocus>
        <button type="submit" class="password-submit">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </button>
      </div>
    {%- endform -%}
  </div>
</body>
</html>
